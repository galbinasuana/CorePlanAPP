                            WidthRequest="100"/>

                        <Button Grid.Column="4"
                            Text="Reset"
                            Command="{Binding ResetFiltersCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#6E6E6E"
                            FontAttributes="Bold"
                            BorderColor="#6E6E6E"
