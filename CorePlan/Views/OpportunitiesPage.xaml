<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="CorePlan.Views.OpportunitiesPage"
             BackgroundColor="#f4f7fc">

    <Grid ColumnDefinitions="200, *">
        <StackLayout BackgroundColor="#1A2A47" Padding="20" Spacing="16">
            <Label Text="CorePlan" FontSize="22" TextColor="White" FontAttributes="Bold"/>
            <Label Text="Dashboard" TextColor="White">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDashboardTapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="• Opportunities" TextColor="#8ab4f8" FontAttributes="Bold"/>
            <Label Text="Calendar" TextColor="White">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCalendarTapped" />
                </Label.GestureRecognizers>
            </Label>

            <StackLayout Padding="10" Spacing="5" Margin="0,210,0,0">
                <Label Text="Client" TextColor="White" FontSize="13"/>
                <Picker 
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="13"
                    ItemsSource="{Binding ClientNameList}"
                    SelectedItem="{Binding SelectedClient}"/>

                <Label Text="Value (€)" TextColor="White" FontSize="13" Margin="0,10,0,0"/>
                <Slider Minimum="{Binding MinValue}"
                    Maximum="{Binding MaxValue}"
                    Value="{Binding SelectedMaxValue}"
                    MinimumTrackColor="#8ab4f8"
                    MaximumTrackColor="LightGray"
                    ThumbColor="White" />
                <Label Text="{Binding SelectedMaxValue, StringFormat='Up to {0:F0} €'}"
                   TextColor="White"
                   FontSize="12"
                   HorizontalOptions="Center" />

                <Label Text="Deal Stage" TextColor="White" FontSize="13" Margin="0,10,0,0"/>
                <Picker
                    x:Name="StagePicker"
                    ItemsSource="{Binding DealStages}"
                    SelectedItem="{Binding SelectedDealStage}"
                    TextColor="White"
                    FontSize="13"
                    BackgroundColor="Transparent"
                    HorizontalOptions="FillAndExpand"/>

                <StackLayout Orientation="Horizontal" Spacing="12" HorizontalOptions="Center" Margin="0,30,0,0">
                    <Button Text="Reset"
                         Clicked="OnResetFiltersClicked"
                         BackgroundColor="Transparent"
                         TextColor="White"
                         BorderColor="White"
                         BorderWidth="1"
                         Padding="10,5" />
                    <Button Text="Apply"
                         Command="{Binding ApplyFiltersCommand}"
                         BackgroundColor="White"
                         TextColor="#1A2A47"
                         FontAttributes="Bold"
                         Padding="10,5" />
                </StackLayout>
            </StackLayout>
        </StackLayout>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="30" Spacing="30">

                <Grid ColumnDefinitions="*,Auto" Padding="30,10">
                    <Label Text="Sales Opportunities"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1A2A47" />

                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <Label Text="Sales Departments" 
                           FontSize="16"
                           FontFamily="Poppins"
                           TextColor="#1A2A47"
                           VerticalOptions="Center"/>

                        <Label Text="•"
                           FontSize="16"
                           TextColor="#1A2A47"
                           VerticalOptions="Center"/>

                        <Label Text="Logout"
                           FontSize="16"
                           FontFamily="Poppins"
                           TextColor="#1A2A47"
                           VerticalOptions="Center"
                           TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogoutClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </Grid>


                <!--<VerticalStackLayout Spacing="12" WidthRequest="800" HorizontalOptions="Start" Margin="0,-20,0,0">
                    <Grid ColumnDefinitions="160,160,160,Auto,Auto" RowDefinitions="Auto">
                        <Frame Grid.Column="0"
                           Padding="0"
                           CornerRadius="6"
                           BackgroundColor="#f5f6f8"
                           HasShadow="False"
                           VerticalOptions="Center"
                           HeightRequest="42">
                            <Grid>
                                <Label Text="Select Client"
                                   TextColor="#6E6E6E"
