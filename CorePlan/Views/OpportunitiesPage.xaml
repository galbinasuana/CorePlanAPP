                </VerticalStackLayout>-->


                <Grid ColumnDefinitions="2.5*,1.5*" ColumnSpacing="30">
                    <VerticalStackLayout Grid.Column="0" Spacing="10">
                        <Grid ColumnDefinitions="*,*,*,*,*"
                              BackgroundColor="#f0f2f8"
                              Padding="10">
                            <Label Text="Client" Grid.Column="0" FontAttributes="Bold" TextColor="#1A2A47" HorizontalOptions="Center"/>
                            <Label Text="Opportunity" Grid.Column="1" FontAttributes="Bold" TextColor="#1A2A47" HorizontalOptions="Center"/>
                            <Label Text="Status" Grid.Column="2" FontAttributes="Bold" TextColor="#1A2A47" HorizontalOptions="Center"/>
                            <Label Text="Value (€)" Grid.Column="3" FontAttributes="Bold" TextColor="#1A2A47" HorizontalOptions="Center"/>
                            <Label Text="Expected Close" Grid.Column="4" FontAttributes="Bold" TextColor="#1A2A47" HorizontalOptions="Center"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding Deals}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,*,*,*,*" Padding="10" BackgroundColor="White">
                                        <Label Grid.Column="0" Text="{Binding ClientName}" TextColor="#6E6E6E" HorizontalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding DealName}" TextColor="#6E6E6E" HorizontalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding DealStage}" TextColor="#6E6E6E" HorizontalOptions="Center"/>
                                        <Label Grid.Column="3" Text="{Binding ExpectedValue}" TextColor="#6E6E6E" HorizontalOptions="Center"/>
                                        <Label Grid.Column="4" Text="{Binding CloseDateFormatted}" TextColor="#6E6E6E" HorizontalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <HorizontalStackLayout HorizontalOptions="End" Spacing="20" Margin="0,10,0,0">
                            <Button Text="« Prev"
                                FontAttributes="Bold"
                                BackgroundColor="#f0f2f8"
                                TextColor="#6E6E6E"
                                CornerRadius="6"
                                Padding="10,5"
                                Clicked="OnPrevPageClicked" />

                            <Label Text="{Binding PageInfoText}"
                               FontAttributes="Bold"
                               TextColor="#1A2A47"
                               VerticalOptions="Center" />

                            <Button Text="Next »"
                                FontAttributes="Bold"
                                BackgroundColor="#f0f2f8"
                                TextColor="#6E6E6E"
                                CornerRadius="6"
                                Padding="10,5"
                                Clicked="OnNextPageClicked" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Frame Grid.Column="1"
                           BackgroundColor="White"
                           CornerRadius="12"
                           Padding="10"
                           HasShadow="True"
                           Margin="0,-20,0,0"
                           VerticalOptions="Start">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Add Opportunity"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A2A47"
                               Margin="0,0,0,10"/>

                            <Label Text="Client" TextColor="Black" FontSize="13"/>
                            <Frame Padding="0" CornerRadius="6" BackgroundColor="#f5f6f8" HasShadow="False">
                                <Entry Placeholder="Client Name" BackgroundColor="Transparent" TextColor="#6E6E6E"/>
                            </Frame>

                            <Label Text="Opportunity" TextColor="Black" FontSize="13"/>
                            <Frame Padding="0" CornerRadius="6" BackgroundColor="#f5f6f8" HasShadow="False">
                                <Entry Placeholder="Opportunity Name" BackgroundColor="Transparent" TextColor="#6E6E6E"/>
                            </Frame>

                            <Label Text="Status" TextColor="Black" FontSize="13"/>
                            <Frame Padding="0" CornerRadius="6" BackgroundColor="#f5f6f8" HasShadow="False">
                                <Picker BackgroundColor="Transparent" TextColor="#6E6E6E">
                                    <Picker.Items>
                                        <x:String>Active</x:String>
                                        <x:String>Pending</x:String>
                                        <x:String>Negotiation</x:String>
                                        <x:String>Closed</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Frame>

                            <Label Text="Value (€)" TextColor="Black" FontSize="13"/>
                            <Frame Padding="0" CornerRadius="6" BackgroundColor="#f5f6f8" HasShadow="False">
                                <Entry Placeholder="Estimated Value"
                                   BackgroundColor="Transparent"
                                   TextColor="#6E6E6E"
                                   Keyboard="Numeric"/>
                            </Frame>

                            <Label Text="Expected Close Date" TextColor="Black" FontSize="13"/>
                            <Frame Padding="0" CornerRadius="6" BackgroundColor="#f5f6f8" HasShadow="False">
                                <DatePicker TextColor="#6E6E6E" BackgroundColor="Transparent"/>
                            </Frame>

                            <Button Text="Add Opportunity"
                                BackgroundColor="#1A2A47"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                Margin="0,10,0,0"
                                HeightRequest="44"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>