                                Minimum="{Binding MinValue}"
                                Maximum="{Binding MaxValue}"
                                Value="{Binding SelectedMaxValue, Mode=TwoWay}"
                                ThumbColor="#1A2A47"
                                MaximumTrackColor="#cbd5e1"
                                MinimumTrackColor="#1A2A47"
                                HeightRequest="40"/>
                            <Label Text="{Binding SelectedMaxValue, StringFormat='Up to {0:F0} €'}"
                                FontSize="12" TextColor="#1A2A47" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>


